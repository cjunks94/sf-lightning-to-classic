{
  "manifest_version": 3,
  "name": "SF Lightning to Classic",
  "short_name": "SF→Classic",
  "version": "1.0.0",
  "homepage_url": "https://github.com/cjunks94/sf-lightning-to-classic",
  "description": "Redirects Salesforce Lightning record pages to Classic view",
  "minimum_chrome_version": "121",
  "permissions": ["declarativeNetRequest", "storage"],
  "host_permissions": [
    "https://*.lightning.force.com/*",
    "https://*.my.salesforce.com/*"
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
